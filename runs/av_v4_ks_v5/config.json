{
  "data_root": "dataset/kinect_sound",
  "class_file": "ICCV2025-GDL-main/dataset/data/KineticSound/class.txt",
  "output_dir": "runs/av_v4_ks_v5",
  "modality": "av",
  "epochs": 80,
  "batch_size": 20,
  "lr": 0.005,
  "lr_scheduler": "multistep",
  "lr_decay_step": "[30,50,70]",
  "lr_decay_ratio": 0.1,
  "momentum": 0.9,
  "weight_decay": 0.0001,
  "audio_loss_weight": 1.0,
  "visual_loss_weight": 5.0,
  "use_video_frames": 3,
  "image_size": 224,
  "audio_duration": 5.0,
  "n_fft": 256,
  "hop_length": 128,
  "win_length": 256,
  "seed": 42,
  "num_workers": 4,
  "device": "cuda",
  "pin_memory": true,
  "deterministic": false,
  "no_progress": false,
  "fgm": true,
  "fgm_lambda": 0.5,
  "fgm_tau": 1.0,
  "fgm_momentum": 0.9,
  "fgm_warmup_steps": 15,
  "num_classes": 33
}