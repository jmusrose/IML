{
  "data_root": "dataset/AVE",
  "output_dir": "runs/av_v4_ave_v5",
  "modality": "av",
  "epochs": 120,
  "batch_size": 12,
  "lr": 0.002,
  "lr_scheduler": "multistep",
  "lr_decay_step": "[40]",
