  "seed": 0,
  "num_workers": 4,
  "device": "cuda",
  "pin_memory": true,
  "deterministic": false,
  "no_progress": false,
  "fgm": true,
  "fgm_lambda": 0.5,
  "fgm_tau": 1.0,
  "fgm_momentum": 0.9,
  "fgm_warmup_steps": 15,
  "num_classes": 28
}